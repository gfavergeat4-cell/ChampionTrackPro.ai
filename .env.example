# Firebase (actuel — l'app tourne avec ça)
# -> voir services/firebaseConfig.js (clés publiques web)

# Supabase (migration — remplir puis EXPO_PUBLIC_USE_SUPABASE=1)
EXPO_PUBLIC_USE_SUPABASE=0
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# VAPID Web Push (clé publique = côté client, clé privée = secrets Supabase)
EXPO_PUBLIC_VAPID_PUBLIC_KEY=

# Edge functions (secrets côté Supabase, jamais dans l'app)
# supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# supabase secrets set VAPID_PRIVATE_KEY=... VAPID_PUBLIC_KEY=...
